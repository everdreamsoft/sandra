# Copy this file to .env and adjust values before running `docker compose up`.
# docker compose automatically picks up `.env` in this directory.

# MySQL passwords — change before any non-local deployment.
SANDRA_DB_PASS=sandra
MYSQL_ROOT_PASSWORD=root

# Optional: require a Bearer token on every MCP call.
# Generate with: openssl rand -hex 32
# REQUIRED if you enable the `tunnel` profile (cloudflared) — the trycloudflare URL
# is publicly reachable, anyone with it can hit your Sandra otherwise.
SANDRA_AUTH_TOKEN=

# Optional: enables sandra_semantic_search and auto-embedding on entity create/update.
# Cost: ~$0.02 per 1M tokens. Sandra works without it; you just lose semantic search.
OPENAI_API_KEY=
